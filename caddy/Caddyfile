panel.parthbhargava.com {
	reverse_proxy pterodactyl_panel:80
}

node.parthbhargava.com {
    reverse_proxy http://wings:8880 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

auth.parthbhargava.com {
  reverse_proxy authelia:9091
}

homer.parthbhargava.com {
  forward_auth authelia:9091 {
    uri /api/verify?rd=https://auth.parthbhargava.com
    copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
  }

  reverse_proxy homer:8080
}

portainer.parthbhargava.com {
  forward_auth authelia:9091 {
    uri /api/verify?rd=https://auth.parthbhargava.com
    copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
  }

  reverse_proxy http://portainer:9000 {
    header_up Host {host}
    header_up X-Forwarded-Host {host}
    header_up X-Forwarded-Proto https
    header_up X-Forwarded-For {remote}
  }
}
